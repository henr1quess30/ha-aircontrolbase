{
  "config": {
    "step": {
      "user": {
        "title": "AirControlBase login",
        "description": "Enter your AirControlBase (CCM21) account credentials.",
        "data": {
          "account": "Email / account",
          "password": "Password"
        }
      },
      "userid": {
        "title": "userId not auto-detected",
        "description": "Login OK for {account}, but the userId could not be extracted from the response. Paste it manually (find it in DevTools → Network on aircontrolbase.com, any request shows `userId=...` in the form data).",
        "data": {
          "user_id": "userId"
        }
      }
    },
    "error": {
      "invalid_auth": "Invalid email or password.",
      "invalid_user_id": "userId rejected by the API.",
      "cannot_connect": "Could not reach AirControlBase."
    },
    "abort": {
      "already_configured": "This account is already configured."
    }
  },
  "entity": {
    "climate": {
      "ac": {
        "state_attributes": {
          "fan_mode": {
            "state": {
              "off": "Off",
              "low": "Low",
              "mid": "Medium",
              "high": "High",
              "auto": "Auto"
            }
          }
        }
      }
    },
    "sensor": {
      "acs_cool": { "name": "ACs cooling" },
      "acs_heat": { "name": "ACs heating" },
      "acs_fan":  { "name": "ACs in fan mode" },
      "acs_stop": { "name": "ACs off" },
      "acs_lock": { "name": "ACs locked" },
      "acs_error":{ "name": "ACs with error" },
      "acs_total":{ "name": "Total ACs" },
      "recent_errors": { "name": "Recent error events" },
      "recent_ops":    { "name": "Recent operation events" },
      "last_event":    { "name": "Last event" }
    },
    "switch": {
      "lock_remote": { "name": "Lock IR remote" },
      "lock_mode":   { "name": "Lock mode" },
      "lock_cool":   { "name": "Lock cool mode" },
      "lock_heat":   { "name": "Lock heat mode" },
      "lock_wind":   { "name": "Lock fan" }
    }
  },
  "services": {
    "create_schedule": {
      "name": "Create schedule",
      "description": "Creates a booking/schedule on AirControlBase for one or more ACs.",
      "fields": {
        "device_ids":  { "name": "Devices",      "description": "AC IDs." },
        "timer":       { "name": "Time",         "description": "HH:MM (24h)." },
        "mode":        { "name": "Mode",         "description": "AC mode." },
        "temperature": { "name": "Temperature",  "description": "Target temperature (°C)." },
        "fan_mode":    { "name": "Fan",          "description": "Fan speed." },
        "weeks":       { "name": "Weekdays",     "description": "1=Mon ... 7=Sun. Empty = all days." },
        "cycle":       { "name": "Recurring",    "description": "Repeats weekly." }
      }
    },
    "update_schedule": {
      "name": "Update schedule",
      "description": "Updates an existing schedule (requires sid).",
      "fields": {
        "schedule_id": { "name": "Schedule ID",  "description": "Existing schedule sid." },
        "device_ids":  { "name": "Devices",      "description": "AC IDs." },
        "timer":       { "name": "Time",         "description": "HH:MM." },
        "mode":        { "name": "Mode",         "description": "AC mode." },
        "temperature": { "name": "Temperature",  "description": "Target temperature (°C)." },
        "fan_mode":    { "name": "Fan",          "description": "Fan speed." },
        "weeks":       { "name": "Weekdays",     "description": "1=Mon ... 7=Sun." },
        "cycle":       { "name": "Recurring",    "description": "Repeats weekly." }
      }
    },
    "refresh":      { "name": "Refresh",      "description": "Force an immediate state poll." },
    "refresh_logs": { "name": "Refresh logs", "description": "Force an immediate log poll." },
    "get_control_log": {
      "name": "Get control log",
      "description": "Returns the control log (controlLog) for a specific device.",
      "fields": {
        "device_id": { "name": "Device ID",      "description": "AC ID." },
        "page":      { "name": "Page",           "description": "Page number." },
        "page_size": { "name": "Page size",      "description": "Records per page." }
      }
    }
  }
}
